# Python
__pycache__/
*.py[cod]
*.egg-info/
.pytest_cache/
.mypy_cache/

# Virtual environment
.venv/

# Local databases — production DB lives on a mounted volume, not in git.
*.db
*.db-shm
*.db-wal

# Local credentials and session state — real per-agent secrets, never committed.
.bardo/
.bardo-dev/
.bardo-local-retired/

# Private key proving bardo.id's ownership to the MCP registry (HTTP domain
# auth). Only the public half is ever served (atrium/main.py's
# /.well-known/mcp-registry-auth route) — the private key never needs to
# leave this machine, just re-used if the registry login session expires.
mcp-registry-auth/

# The real puzzle facts pool — publishing it would hand out the answer key
# to the human/LLM litmus test the puzzle depends on. facts.example.json
# (a smaller, different set) stays tracked so the open-source code still
# runs; real deployments supply their own facts.json.
atrium/core/facts.json

# Local env vars for running admin scripts (feedback_admin.py,
# platform_stats.py) against production from outside Railway — real DB
# credentials and the feedback decryption key, never committed.
.env

# Editor/OS cruft
.DS_Store
