# Python
__pycache__/
*.py[cod]
*.egg-info/
.pytest_cache/
.mypy_cache/

# Virtual environment
.venv/

# Local databases — production DB lives on a mounted volume, not in git.
*.db
*.db-shm
*.db-wal

# Local credentials and session state — real per-agent secrets, never committed.
.bardo/
.bardo-dev/
.bardo-local-retired/

# Private key proving bardo.id's ownership to the MCP registry (HTTP domain
# auth). Only the public half is ever served (atrium/main.py's
# /.well-known/mcp-registry-auth route) — the private key never needs to
# leave this machine, just re-used if the registry login session expires.
mcp-registry-auth/

# Editor/OS cruft
.DS_Store
